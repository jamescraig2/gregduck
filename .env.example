# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=   # Clerk dashboard -> API Keys -> Publishable Key
CLERK_SECRET_KEY=                    # Clerk dashboard -> API Keys -> Secret Key

# Neon Serverless Postgres
DATABASE_URL=                        # Neon console -> Connection Details -> pooled connection string (uses ?pgbouncer=true)
DIRECT_URL=                          # Neon console -> Connection Details -> direct (unpooled) connection string

# Google Gemini API
GEMINI_API_KEY=                      # Google AI Studio or GCP Vertex AI -> API Key

# Google Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=     # GCP -> APIs & Services -> Credentials -> Maps API Key
NEXT_PUBLIC_MAP_ID=                  # GCP -> Maps Management -> Map IDs -> Map ID

# Vercel Blob
BLOB_READ_WRITE_TOKEN=               # Vercel dashboard -> Storage -> Blob -> Copy Read & Write Token
BLOB_STORE_ID=                       # Vercel dashboard -> Storage -> Blob -> Store ID
